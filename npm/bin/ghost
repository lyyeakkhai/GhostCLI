#!/usr/bin/env node
/**
 * GhostCLI NPM Wrapper — bin entry point
 *
 * Invokes the platform-native GhostCLI binary downloaded by install.js.
 * Any arguments are passed through verbatim.
 */

const { spawn } = require('child_process');
const fs = require('fs');
const path = require('path');

function getBinaryPath() {
  const ext = process.platform === 'win32' ? '.exe' : '';
  return path.join(__dirname, '..', 'bin', `ghost${ext}`);
}

const binaryPath = getBinaryPath();

if (!fs.existsSync(binaryPath)) {
  console.error(
    'GhostCLI binary not found. Please run:\n' +
    '  npm install\n' +
    'or download manually from https://github.com/ghostcli/ghostcli/releases'
  );
  process.exit(1);
}

const child = spawn(binaryPath, process.argv.slice(2), {
  stdio: 'inherit',
  windowsHide: false,
});

child.on('exit', (code, signal) => {
  if (signal) {
    process.kill(process.pid, signal);
  } else {
    process.exit(code ?? 0);
  }
});
